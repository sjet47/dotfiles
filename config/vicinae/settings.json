{
   "$schema": "https://vicinae.com/schemas/config.json",
   "font": {
      "normal": {
         "family": "JetBrains Mono",
         "size": 12
      }
   },
   "theme": {
      "dark": {
         "name": "one-dark"
      }
   },
   "telemetry": {
      "system_info": false
