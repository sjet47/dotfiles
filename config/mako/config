anchor=top-right
default-timeout=5000
width=420
outer-margin=20
padding=10,15
border-size=1
border-radius=12
max-icon-size=32
font=sans-serif 14px

background-color=#f5f5f7d9
text-color=#1d1d1f
border-color=#d2d2d7
progress-color=over #0071e3

[urgency=low]
border-color=#e5e5ea

[urgency=critical]
default-timeout=0
layer=overlay
border-color=#ff453a

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[summary~="Screenshot copied & saved"]
max-icon-size=80
format=<b>%s</b>\n%b
