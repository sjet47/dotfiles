.DS_Store
vim/.netrwhist
nvim/plugin

# White list
config/*
pi-agent/*

# Directories
!config/alacritty/
!config/atuin/
!config/zellij/
!config/hypr/
!config/waybar/
!config/vicinae/
!config/kitty/
!config/mako/
!config/systemd/
!config/herdr/
!config/satty/
!config/fontconfig/
!config/environment.d/
!config/environment.d/
!pi-agent/agents
!pi-agent/prompts
!pi-agent/extensions

# Files
!config/okularpartrc
!config/krunnerrc
!config/feishu-flags.conf
!config/code-flags.conf
!pi-agent/hermes-memory-config.json
!pi-agent/mcp.json
!pi-agent/pi-sub-core-settings.json
!pi-agent/pi-sub-bar-settings.json
!pi-agent/pi-tps.json
!pi-agent/settings.json
!pi-agent/subagents.json
config/herdr/*.json
config/herdr/*.log

# hypr local-only 配置:除模板外都不入库
config/hypr/local/*
!config/hypr/local/example.lua
config/hypr/scripts/wallpaper.sh

# 迁移到 hyprland.lua 后,Hyprland 在缺失时会自动生成 hyprland.conf stub,不入库
config/hypr/hyprland.conf

# systemctl --user enable 生成的 symlinks，不入库
config/systemd/user/*.target.wants/

# KDE/Plasma 自动生成,机器相关,只保留 conf.d 里我们自己的配置
config/fontconfig/fonts.conf
